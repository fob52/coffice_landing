<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Coffice – Map. Sip. Work.</title>
<meta name="description" content="Coffice is the community-powered map of the best cafés to work from. Find Wi-Fi passwords, outlets, and hidden gems near you.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --espresso: #3B1A08;
    --dark-roast: #5C2E0E;
    --caramel: #D4B896;
    --cream: #F5EFE6;
    --oat: #EDE4D6;
    --foam: #FAF6F0;
    --text-dark: #1C0D03;
    --text-mid: #6B4226;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--espresso);
    color: var(--cream);
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.35;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(59,26,8,0.95) 0%, transparent 100%);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--cream);
    letter-spacing: -0.5px;
  }

  .nav-logo span {
    color: var(--caramel);
  }

  .nav-cta {
    background: var(--cream);
    color: var(--espresso);
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    padding: 10px 22px;
    border-radius: 100px;
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: all 0.2s ease;
  }

  .nav-cta:hover {
    background: #fff;
    transform: translateY(-1px);
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-circle {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196,129,42,0.15) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--caramel);
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.1s;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.5rem, 10vw, 7.5rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -3px;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.2s;
  }

  .hero-title .coffee-o {
    display: inline-block;
    position: relative;
    color: var(--caramel);
  }

  .hero-tagline-block {
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.35s;
  }

  .hero-tagline {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--oat);
    opacity: 0.85;
  }

  .hero-dots {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
    margin: 16px 0 0;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.45s;
  }

  .hero-dots span {
    font-size: 0.7rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--caramel);
    font-weight: 500;
  }

  .hero-dots .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--caramel);
    opacity: 0.6;
  }

  .hero-desc {
    max-width: 480px;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--oat);
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.5s;
    margin-bottom: 40px;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.6s;
  }

  .btn-appstore {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--cream);
    color: var(--espresso);
    padding: 14px 28px;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  .btn-appstore:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(0,0,0,0.4);
    background: #fff;
  }

  .btn-appstore svg { width: 22px; height: 22px; }

  .btn-appstore-inner { text-align: left; }
  .btn-appstore-sub { font-size: 0.65rem; opacity: 0.6; display: block; letter-spacing: 0.5px; text-transform: uppercase; }
  .btn-appstore-main { font-size: 1rem; font-weight: 600; display: block; line-height: 1.1; }

  .btn-web {
    font-size: 1rem;
    font-weight: 500;
    color: var(--cream);
    opacity: 0.9;
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: all 0.2s;
    border-bottom: 2px solid rgba(237,228,214,0.5);
    padding-bottom: 3px;
  }

  .btn-web:hover { opacity: 1; border-bottom-color: var(--cream); }

  /* ── PHONE MOCKUPS ── */
  .phones-section {
    padding: 60px 24px 100px;
    display: flex;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .phones-row {
    display: flex;
    gap: 20px;
    align-items: flex-end;
    max-width: 800px;
    width: 100%;
    justify-content: center;
  }

  .phone-card {
    flex: 0 0 auto;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.5);
    opacity: 0;
    animation: fadeUp 0.8s ease forwards;
  }

  .phone-card:nth-child(1) { width: 220px; animation-delay: 0.2s; transform: rotate(-3deg); }
  .phone-card:nth-child(2) { width: 240px; animation-delay: 0.35s; transform: rotate(0deg) translateY(-20px); }
  .phone-card:nth-child(3) { width: 220px; animation-delay: 0.5s; transform: rotate(3deg); }

  .phone-card img {
    width: 100%;
    display: block;
    border-radius: 28px;
  }

  /* ── FEATURES ── */
  .features {
    background: var(--foam);
    color: var(--text-dark);
    padding: 100px 24px;
  }

  .features-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--caramel);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1px;
    color: var(--espresso);
    margin-bottom: 60px;
    max-width: 560px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
    background: var(--oat);
    border-radius: 24px;
    overflow: hidden;
  }

  .feature-item {
    background: var(--foam);
    padding: 40px 36px;
    transition: background 0.2s;
  }

  .feature-item:hover { background: #fff; }

  .feature-emoji {
    font-size: 2rem;
    margin-bottom: 18px;
    display: block;
  }

  .feature-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    color: var(--espresso);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .feature-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-mid);
  }

  /* ── STATS BAND ── */
  .stats-band {
    background: var(--dark-roast);
    padding: 60px 24px;
  }

  .stats-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    gap: 0;
    justify-content: center;
    flex-wrap: wrap;
  }

  .stat {
    flex: 1;
    min-width: 160px;
    text-align: center;
    padding: 20px 30px;
    border-right: 1px solid rgba(245,239,230,0.1);
  }

  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 900;
    color: var(--caramel);
    line-height: 1;
    display: block;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--oat);
    opacity: 0.7;
    letter-spacing: 0.5px;
    margin-top: 6px;
  }

  /* ── QUOTE / COMMUNITY ── */
  .community {
    background: var(--espresso);
    padding: 100px 24px;
    text-align: center;
  }

  .community-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .quote-mark {
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    color: var(--caramel);
    opacity: 0.4;
    line-height: 0.5;
    margin-bottom: 24px;
    display: block;
  }

  .community-quote {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(1.4rem, 4vw, 2.1rem);
    line-height: 1.35;
    color: var(--cream);
    margin-bottom: 32px;
  }

  .community-sub {
    font-size: 0.9rem;
    color: var(--oat);
    opacity: 0.65;
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto 48px;
  }

  /* ── FINAL CTA ── */
  .final-cta {
    background: #C8B89A;
    padding: 100px 24px;
    text-align: center;
  }

  .final-cta-inner { max-width: 600px; margin: 0 auto; }

  .final-cta-label {
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--espresso);
    opacity: 0.7;
    margin-bottom: 20px;
  }

  .final-cta-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -2px;
    color: var(--espresso);
    margin-bottom: 16px;
  }

  .final-cta-sub {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--espresso);
    opacity: 0.7;
    margin-bottom: 40px;
  }

  .btn-appstore-dark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--espresso);
    color: var(--cream);
    padding: 14px 28px;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    margin-bottom: 20px;
  }

  .btn-appstore-dark:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(0,0,0,0.3);
  }

  .btn-appstore-dark svg { width: 22px; height: 22px; }

  /* ── FOOTER ── */
  footer {
    background: var(--text-dark);
    padding: 40px 24px;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 900;
    color: var(--cream);
    opacity: 0.8;
    margin-bottom: 12px;
  }

  .footer-logo span { color: var(--caramel); }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.8rem;
    color: var(--oat);
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-links a:hover { opacity: 1; }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--oat);
    opacity: 0.35;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .phone-card:nth-child(1) { animation-name: fadeUpRotL; }
  .phone-card:nth-child(2) { animation-name: fadeUpCenter; }
  .phone-card:nth-child(3) { animation-name: fadeUpRotR; }

  @keyframes fadeUpRotL {
    from { opacity: 0; transform: translateY(40px) rotate(-3deg); }
    to   { opacity: 1; transform: translateY(0) rotate(-3deg); }
  }
  @keyframes fadeUpCenter {
    from { opacity: 0; transform: translateY(40px) translateY(-20px) rotate(0deg); }
    to   { opacity: 1; transform: translateY(-20px) rotate(0deg); }
  }
  @keyframes fadeUpRotR {
    from { opacity: 0; transform: translateY(40px) rotate(3deg); }
    to   { opacity: 1; transform: translateY(0) rotate(3deg); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    nav { padding: 16px 20px; }
    .phones-row { gap: 10px; }
    .phone-card:nth-child(1) { width: 130px; }
    .phone-card:nth-child(2) { width: 150px; }
    .phone-card:nth-child(3) { width: 130px; }
    .stats-inner { gap: 0; }
    .stat { min-width: 120px; padding: 16px 18px; }
    .stat-num { font-size: 2.2rem; }
    .feature-item { padding: 28px 24px; }
  }

  @media (max-width: 400px) {
    .phone-card:nth-child(3) { display: none; }
    .phone-card:nth-child(1) { width: 150px; }
    .phone-card:nth-child(2) { width: 170px; }
  }
</style>
</head>
